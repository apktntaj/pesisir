# Server
PORT=3001
HOST=0.0.0.0

# INSW Government API
LARTAS_BASE_URL=https://api.insw.go.id

# Token (file path, or TOKEN env var as fallback for platforms like Railway)
TOKEN_FILE_PATH=./token.txt

# Request settings
REQUEST_TIMEOUT_MS=30000
MAX_RETRIES=3

# Logging (debug | info | warn | error)
LOG_LEVEL=info

# Optional: API key for frontend-to-backend authentication
# If set, requests to /lartas require x-api-key header
API_KEY=

# Optional: Admin key for token management endpoints
# If set, requests to POST /admin/token require x-admin-key header
ADMIN_KEY=
